# ============================================
# DealGapIQ Frontend — Environment Variables
# ============================================
# Copy this file to .env.local and fill in real values:
#   cp .env.example .env.local
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All others are server-side only.
# ============================================

# ── Required ─────────────────────────────────

# API URL used by Next.js rewrites (server-side proxy target).
# On Vercel this MUST be your public backend URL (e.g. https://your-app.up.railway.app).
# Never use a private/internal hostname (e.g. *.railway.internal) or you will get
# 404 DNS_HOSTNAME_RESOLVED_PRIVATE when using Google sign-in or API rewrites.
NEXT_PUBLIC_API_URL=https://your-backend-url.example.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional: set to true only when you intentionally want browser requests to bypass
# same-origin rewrites and call NEXT_PUBLIC_API_URL directly (can trigger CORS).
# NEXT_PUBLIC_USE_DIRECT_API=false

# Backend URL for server-side API route proxying (Next.js server → backend).
# Must be the same public backend URL as above, NOT a Vercel or private URL.
BACKEND_URL=https://your-backend-url.example.com

# ── Optional ─────────────────────────────────

# Google Maps: enable Address Autocomplete (client) and Address Validation (server).
# - NEXT_PUBLIC_GOOGLE_MAPS_API_KEY: used in the browser for Places Autocomplete (search input).
# - GOOGLE_MAPS_API_KEY: used only on the server for Address Validation API; never exposed to client.
# Enable both "Places API (New)" or "Places API" and "Address Validation API" in Google Cloud Console.
# Restrict keys to your domain(s) and APIs to minimize risk.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# GOOGLE_MAPS_API_KEY=

# Sentry DSN for client-side error tracking (disabled if unset)
# NEXT_PUBLIC_SENTRY_DSN=
