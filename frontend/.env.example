# Frontend environment variables (Next.js). Copy to .env.local for development.
# NEXT_PUBLIC_* values are exposed to the browser — never put secrets here.

# Backend API base URL (empty = same-origin proxy via Next.js rewrites)
NEXT_PUBLIC_API_URL=

# PostHog product analytics (consent-gated; loads only after the user accepts
# analytics cookies). Project API key from PostHog -> Project Settings.
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key
# Use https://eu.i.posthog.com for EU Cloud accounts.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Apple numeric App Store ID (App Store Connect -> App Information -> Apple ID).
# Powers the iOS Safari Smart App Banner and the /get-app iOS install link.
# Leave unset until the app is live; the banner is omitted and iOS links fall
# back to an App Store brand search.
NEXT_PUBLIC_APPLE_APP_ID=
